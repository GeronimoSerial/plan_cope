{
  "name": "plan-cope",
  "version": "0.1.0",
  "description": "Plataforma de evaluaciones offline-first",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "preview": "turbo run preview",
    "lint": "turbo run lint --filter='!apps/*' -- --max-warnings 0",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test -- --watch",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "db:generate": "turbo run db:generate",
    "db:reset": "bash scripts/reset-db.sh",
    "validate:schemas": "cd packages/shared-domain && pnpm exec tsx ../../scripts/validate-schemas.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo clean && find . -type d -name node_modules -prune -exec rm -rf {} + && rm -rf pnpm-lock.yaml"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "js-yaml": "^4.2.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.3.0"
}
