{
  "name": "@plan-cope/local",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server/app.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "echo 'migrations run automatically on app start (runMigrations)'",
    "db:seed": "echo 'seeders in PR3'",
    "dev": "tsx watch src/server/app.ts",
    "start": "node dist/server/app.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@plan-cope/shared-domain": "workspace:*",
    "@plan-cope/shared-schemas": "workspace:*",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "fastify": "^5.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@plan-cope/eslint-config": "workspace:*",
    "@plan-cope/tsconfig": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
