# apps/central — environment variables.
# Copy to `.env` and fill in. Never commit `.env`.

# PostgreSQL connection string. Format: postgres://USER:PASS@HOST:PORT/DB
DATABASE_URL=postgres://plan_cope:plan_cope_dev@localhost:5432/plan_cope

# HTTP server port. Default: 3000.
PORT=3000

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
