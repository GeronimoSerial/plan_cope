# URL del Central API (.NET). SOLO servidor — no usar prefijo NEXT_PUBLIC.
# El navegador nunca habla con esta URL directamente: pasa por el BFF (/api/*).
CENTRAL_API_URL=https://localhost:7088

# Opcional. En desarrollo se acepta el certificado self-signed de https://localhost.
# Poné "false" para exigir certificado válido también en desarrollo.
# CENTRAL_API_ALLOW_INSECURE=false

# Opcional (solo WSL): redirige el directorio de build .next a un path Linux
# para evitar errores de escritura sobre el mount de Windows.
# NEXT_DIST_DIR=/tmp/plancope-next-build
