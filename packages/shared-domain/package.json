{
  "name": "@plan-cope/shared-domain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/index.ts",
    "./db/migrator": "./src/db/migrator.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "echo 'migrator invoked programmatically by apps; use runMigrations()'",
    "db:seed": "echo 'seeders implemented in PR3'"
  },
  "dependencies": {
    "@plan-cope/shared-schemas": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.36.4",
    "drizzle-zod": "^0.5.1",
    "postgres": "^3.4.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@plan-cope/eslint-config": "workspace:*",
    "@plan-cope/tsconfig": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.0.0",
    "pg": "^8.13.1",
    "tsx": "^4.22.4",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
